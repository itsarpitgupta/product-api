{
    "family": "product-api-task",
    "networkMode": "bridge",
    "requiresCompatibilities": [
        "EC2"
    ],
    "cpu": "512",
    "memory": "800",
    "executionRoleArn": "arn:aws:iam::606349122774:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "product-api",
            "image": "606349122774.dkr.ecr.us-east-1.amazonaws.com/product-api:v3",
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true
        }
    ]
}